generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Operator {
  ADD
  SUBTRACT
  MULTIPLY
  DIVIDE
}

model ProblemDefinition {
  id         Int      @id @default(autoincrement())
  hash       String
  leftValue  Float
  rightValue Float
  operator   Operator
  answer     Float

  FinishedRound FinishedRound[]

  @@unique([hash, leftValue, rightValue, operator, answer])
  @@index([hash])
}

model FinishedGame {
  id         Int             @id @default(autoincrement())
  userId     String
  startedAt  DateTime
  finishedAt DateTime        @default(now())
  rounds     FinishedRound[]
}

model FinishedRound {
  id          Int            @id @default(autoincrement())
  attempts    RoundAttempt[]
  isCompleted Boolean
  durationMs  Int

  problem   ProblemDefinition @relation(fields: [problemId], references: [id])
  problemId Int

  game   FinishedGame @relation(fields: [gameId], references: [id])
  gameId Int
}

model RoundAttempt {
  id       Int   @id @default(autoincrement())
  ordering Int
  value    Float

  round   FinishedRound @relation(fields: [roundId], references: [id])
  roundId Int
}
