// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

enum Operator {
  ADD
  SUBTRACT
  MULTIPLY
  DIVIDE
}

model RoundAttempt {
  id       Int @id @default(autoincrement())
  ordering Int
  value    Int

  round   FinishedRound @relation(fields: [roundId], references: [id])
  roundId Int

  @@index([roundId])
}

model FinishedRound {
  id         Int      @id @default(autoincrement())
  leftValue  Int
  rightValue Int
  operator   Operator
  answer     Int

  attempts    RoundAttempt[]
  isCompleted Boolean
  durationMs  Int

  game   FinishedGame @relation(fields: [gameId], references: [id])
  gameId Int

  @@index([gameId])
}

model FinishedGame {
  id         Int             @id @default(autoincrement())
  userId     String
  startedAt  DateTime
  finishedAt DateTime        @default(now())
  rounds     FinishedRound[]
}
