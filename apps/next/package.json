{
  "name": "@munk/nextjs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm with-env next build",
    "clean": "git clean -xdf .next .turbo node_modules",
    "dev": "pnpm with-env next dev",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "start": "pnpm with-env next start",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@munk/api": "workspace:*",
    "@munk/db": "workspace:*",
    "@munk/ui": "workspace:*",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tanstack/react-query": "catalog:",
    "@trpc/client": "catalog:",
    "@trpc/react-query": "catalog:",
    "@trpc/server": "catalog:",
    "geist": "^1.5.1",
    "next": "^15.5.19",
    "react": "catalog:react18",
    "react-dom": "catalog:react18",
    "superjson": "^2.2.6",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@munk/eslint-config": "workspace:*",
    "@munk/prettier-config": "workspace:*",
    "@munk/tailwind-config": "workspace:*",
    "@munk/tsconfig": "workspace:*",
    "@types/node": "^22.15.0",
    "@types/react": "catalog:react18",
    "@types/react-dom": "catalog:react18",
    "dotenv-cli": "^11.0.0",
    "eslint": "catalog:",
    "jiti": "^2.7.0",
