{
  "name": "mathgame",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "db:setup": "yarn with-dev-env prisma db seed",
    "db:generate": "yarn with-dev-env prisma generate",
    "db:start": "yarn with-dev-env ./start-database.sh",
    "db:push": "yarn with-dev-env prisma db push && prisma generate",
    "db:studio": "yarn with-dev-env prisma studio",
    "dev": "yarn with-dev-env next dev",
    "with-dev-env": "dotenv -e .env.dev --",
    "postinstall": "prisma generate",
    "lint": "next lint",
    "start": "next start",
    "format": "yarn eslint --fix . && npx prettier --write ."
  },
