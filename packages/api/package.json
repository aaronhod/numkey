    "lint": "eslint",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@munk/auth": "workspace:*",
    "@munk/db": "workspace:*",
    "@munk/domain": "workspace:*",
    "@hono/trpc-server": "^0.1.0",
    "@trpc/server": "^10.43.2",
    "hono": "^3.9.2",
    "superjson": "^2.2.1"
  },
  "devDependencies": {
    "@munk/eslint-config": "workspace:*",
    "@munk/prettier-config": "workspace:*",
    "@munk/tsconfig": "workspace:*",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@munk/prettier-config"
}
