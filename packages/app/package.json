    "@rn-primitives/progress": "~1.0.3",
    "@rn-primitives/slot": "~1.0.3",
    "@rn-primitives/tooltip": "~1.0.3",
    "@rn-primitives/types": "~1.0.3",
    "@shopify/flash-list": "^1.6.3",
    "@supabase/supabase-js": "^2.38.4",
