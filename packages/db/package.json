{
  "name": "@munk/db",
  "version": "2.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./dist/src/*.d.ts",
      "default": "./src/*.tsx"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc",
    "setup": "yarn with-dev-env prisma db seed",
    "generate": "yarn with-dev-env prisma generate",
    "start": "yarn with-dev-env ./start-database.sh",
    "push": "yarn with-dev-env prisma db push && prisma generate",
    "studio": "yarn with-dev-env prisma studio",
    "clean": "rm -rf .turbo dist node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "with-dev-env": "dotenv -e .env.dev --"
  },
  "devDependencies": {
    "@munk/eslint-config": "workspace:*",
    "@munk/prettier-config": "workspace:*",
    "@munk/tsconfig": "workspace:*",
    "@types/bun": "^1.1.6",
    "@types/pg": "^8.15.5",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "prisma": "^7.8.0",
    "typescript": "catalog:"
  },
  "dependencies": {
    "@munk/domain": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@t3-oss/env-core": "^0.13.11",
    "pg": "^8.16.3",
    "zod": "catalog:"
  }
}
